{
  "name": "broll-recorder",
  "version": "0.1.5",
  "description": "Simple desktop recorder for reusable social media B-roll.",
  "author": "Mojo Makes",
  "main": "dist/main/app.js",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/mojo-codes/broll-recorder.git"
  },
  "scripts": {
    "dev": "npm run build:main && concurrently -k \"vite --host 127.0.0.1\" \"tsc -p tsconfig.main.json --watch --preserveWatchOutput\" \"wait-on http://127.0.0.1:5173 dist/main/app.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "start": "npm run build && electron .",
    "build": "npm run typecheck && npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "package": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:mac:ci": "npm run build && electron-builder --mac --x64 --publish never",
    "dist:mac:signed-local": "test -n \"$CSC_NAME\" && npm run build && electron-builder --mac --x64 --config.mac.identity=\"$CSC_NAME\" --publish never",
    "release:github": "npm run build && electron-builder --publish always",
    "release:github:mac": "npm run build && electron-builder --mac --x64 --publish always",
    "release:github:win": "npm run build && electron-builder --win --x64 --publish always"
  },
  "dependencies": {
    "electron-log": "^5.4.4",
    "electron-squirrel-startup": "^1.0.1",
    "electron-updater": "^6.8.3",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.mojomakes.brollrecorder",
    "productName": "B-Roll Recorder",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "publish": [
      {
        "provider": "github",
        "owner": "mojo-codes",
        "repo": "broll-recorder",
        "releaseType": "draft"
      }
    ],
    "mac": {
      "identity": "-",
      "category": "public.app-category.video",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
